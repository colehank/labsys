# 复制为 .env 后按需修改。生产（turing）务必改掉密钥与密码。
CIBOL_ENV=dev

# Postgres（compose 内服务名 postgres；本地直连用 localhost）
POSTGRES_PASSWORD=cibol
CIBOL_DATABASE_URL=postgresql+asyncpg://cibol:cibol@postgres:5432/cibol

# Redis
CIBOL_REDIS_URL=redis://redis:6379/0

# JWT —— 生产用 `openssl rand -hex 32` 重新生成
CIBOL_JWT_SECRET=dev-insecure-change-me

# 前端来源（CORS）
CIBOL_CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# dmxapi（LLM 中转平台余额/计量）—— 工作台→个人设置
CIBOL_DMXAPI_BASE=https://www.dmxapi.cn
CIBOL_DMXAPI_SYSTEM_TOKEN=
CIBOL_DMXAPI_USER_ID=

# WebSSH：无需服务端凭据（用户用自己的账号密码连），仅需应用运行在可直连目标机的内网主机。
# SSH 账号下发（管理员远程 useradd）才需要特权账号：
CIBOL_SSH_ADMIN_USER=labadmin
CIBOL_SSH_ADMIN_KEY_PATH=        # labadmin 私钥路径（docker secret 挂载）

# 腾讯会议预约（Playwright 自动化北师大 vc.bnu.edu.cn 校园门户，非腾讯官方 API）
# 配齐 ACCOUNT/PASSWORD 才启用；镜像需 `playwright install --with-deps chromium`
CIBOL_BOOKING_URL=https://vc.bnu.edu.cn
CIBOL_BOOKING_ACCOUNT=           # 校园统一身份认证学号
CIBOL_BOOKING_PASSWORD=          # 门户密码
CIBOL_BOOKING_HEADLESS=true
CIBOL_BOOKING_AUTO_DAYS_AHEAD=3  # 自动预约：组会前几天
