# 复制为根目录 .env 后填写。生产（turing）务必改 JWT_SECRET、POSTGRES_PASSWORD 与各凭据。
# 本地 `uv run` 与 docker compose 都读这一份。
# 注意：DATABASE_URL 不在这里 —— 本地用代码默认 localhost；容器由 compose 注入 postgres 主机。

CIBOL_ENV=dev

# Postgres 密码（容器 postgres 与 compose 注入的 DATABASE_URL 共用此值；本地 cibol-pg 用默认 cibol）
POSTGRES_PASSWORD=cibol

# JWT —— 生产用 `openssl rand -hex 32` 重新生成
CIBOL_JWT_SECRET=dev-insecure-change-me

# 前端来源（CORS）—— 生产改成 turing 访问地址
CIBOL_CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# dmxapi（LLM 中转平台余额/计量）
CIBOL_DMXAPI_BASE=https://www.dmxapi.cn
CIBOL_DMXAPI_SYSTEM_TOKEN=
CIBOL_DMXAPI_USER_ID=

# 腾讯会议预约（Playwright 自动化 vc.bnu.edu.cn 校园门户）
CIBOL_BOOKING_URL=https://vc.bnu.edu.cn
CIBOL_BOOKING_ACCOUNT=
CIBOL_BOOKING_PASSWORD=
CIBOL_BOOKING_HEADLESS=true
CIBOL_BOOKING_AUTO_DAYS_AHEAD=3

# SSH 账号下发（WebSSH 不需要；仅"管理员远程开通账号"用）
CIBOL_SSH_ADMIN_USER=labadmin
CIBOL_SSH_ADMIN_KEY_PATH=
